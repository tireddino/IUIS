```gitignore
# Build artifacts and binaries
*.exe
*.dll
*.pdb
*.obj
*.lib
*.so
*.dylib
*.class

# Dependencies
packages/
node_modules/
venv/
.venv/
__pycache__/
*.egg-info/

# IDE specific
.vs/
.vscode/
.idea/
*.userprefs
*.user
*.suo
*.userosscache
*.sln.docstates

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log

# Temp files
*.tmp
*.temp
*~

# Configuration and environment
.env
.env.local
*.env.*
config/
appsettings*.json

# Build outputs
bin/
obj/
Debug/
Release/
build/
dist/
target/

# Testing
coverage/
htmlcov/
*.coverage
.nyc_output/

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```